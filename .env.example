# =============================================================================
# ClawBot Environment Configuration — TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your values.
# Auth / TLS / domain email live in ../auth-portal/.env (see auth-portal repo).
# =============================================================================

# --- Domain (used for Traefik host rule) ---
DOMAIN=domain.com

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-api03-CHANGEME

# --- WhatsApp ---
WHATSAPP_NUMBER=CHANGEME

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_TOKEN=CHANGEME_generate_with_openssl_rand_hex_32
OPENCLAW_CONFIG_DIR=/opt/openclaw/config
OPENCLAW_WORKSPACE_DIR=/opt/openclaw/workspace
